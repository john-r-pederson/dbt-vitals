# --- Warehouse ---
WAREHOUSE_TYPE=snowflake

# --- Snowflake Connection ---
SNOWFLAKE_USER=your_username
SNOWFLAKE_ACCOUNT=your_account_locator   # e.g. myorg-abc12345 (org-account format)
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_ROLE=DBT_VITALS_ROLE

# --- Snowflake Auth (choose one) ---
# Option A: Key-pair auth (required for CI/GitHub Actions)
# SNOWFLAKE_PRIVATE_KEY=<base64-encoded PEM private key>
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=   # leave blank if key is unencrypted

# Option B: Password (basic auth, MFA accounts will reject this)
# SNOWFLAKE_PASSWORD=your_password

# Option C: Browser SSO/MFA (local dev only — opens browser tab)
# Leave both above unset; externalbrowser is the automatic fallback.

# --- dbt-vitals Behavior ---
BASE_BRANCH=main
# MANIFEST_PATH=./target/manifest.json  # auto-discovered if unset

# --- GitHub (injected automatically by GitHub Actions, set manually for local testing) ---
# GITHUB_TOKEN=ghp_...
# GITHUB_REPOSITORY=owner/repo
# PR_NUMBER=42
